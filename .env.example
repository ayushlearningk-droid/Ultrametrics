# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Ads (https://developers.google.com/google-ads/api/docs/get-started/dev-token)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MCC_CUSTOMER_ID=
# Optional; defaults to {NEXT_PUBLIC_APP_URL}/api/connectors/google-ads/oauth/callback
GOOGLE_ADS_OAUTH_REDIRECT_URI=

# Meta Ads OAuth (https://developers.facebook.com/apps/)
META_APP_ID=
META_APP_SECRET=
# Optional; defaults to {NEXT_PUBLIC_APP_URL}/api/connectors/meta/oauth/callback
META_OAUTH_REDIRECT_URI=

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_STARTER_YEARLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_GROWTH_YEARLY=price_...

# C2: 32-byte AES-256-GCM key for OAuth token encryption.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
